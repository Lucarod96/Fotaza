extends layout.pug 

block title
  | Fotaza - Inicio

block styles 
  link(rel="stylesheet", href="/posts.css")

block content
  h1.feed-title Explorar
  
  if posts && posts.length > 0
    div.posts-grid
      each post in posts
        div.post-card
          if post.PostImages && post.PostImages.length > 0
            div.post-image-wrapper
              img(src=post.PostImages[0].imageUrl, alt=post.title)
          else
            div.post-image-placeholder Sin imagen
            
          div.post-info
            h3= post.title
            
            if post.User
              p.post-author Por: 
                a(href=`/profile/${post.User.username}`, class="author-link") @#{post.User.username}
              
            if post.description
              p.post-desc= post.description
              
            div.post-meta-footer
              span.post-rating ★ 4.5
              span.post-license #{post.license}
  else
    div.no-posts
      p No hay publicaciones para mostrar todavía. ¡Sé el primero en subir una!