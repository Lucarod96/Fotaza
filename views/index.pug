extends layout.pug 

block title
  | Fotaza - Inicio

block styles 
  link(rel="stylesheet", href="/posts.css")

block content
  h1.feed-title Explorar
  
  if posts && posts.length > 0
    div.posts-grid
      each post in posts
        div.post-card
          if post.PostImages && post.PostImages.length > 0
            div.post-image-wrapper
              a(href=`/posts/${post.id}`)
                img(src=post.PostImages[0].imageUrl, alt=post.title)
          else
            div.post-image-placeholder Sin imagen
            
          div.post-info
            h3
              a(href=`/posts/${post.id}` style="color: #fff; text-decoration: none;")= post.title
            
            if post.User
              p.post-author Por: 
                a(href=`/profile/${post.User.username}`, class="author-link") @#{post.User.username}
              
            if post.description
              p.post-desc= post.description

            if post.Tags && post.Tags.length > 0
              div.post-tags
                each etiqueta in post.Tags
                  span.tag-badge #{etiqueta.name}
              
            div.post-meta-footer
              if post.Ratings && post.Ratings.length > 0
                - var suma = post.Ratings.reduce((a, b) => a + b.stars, 0)
                - var prom = (suma / post.Ratings.length).toFixed(1)
                span.post-rating(style="color: #ffffff;") ★ #{prom}
              else
                span.post-rating(style="color: #888;") ☆ Sin votos
                
              span.post-license #{post.license}
  else
    div.no-posts
      p No hay publicaciones para mostrar todavía. ¡Sé el primero en subir una!