extends layout.pug

block styles 
  link(rel="stylesheet", href="/posts.css")

block content
  div.profile-header
    div.profile-info-box
      div.profile-name-row
        h1.profile-username @#{profileUser.username}

        if !isOwnProfile
          if isFollowing
            form(action=`/profile/${profileUser.username}/follow`, method="POST")
              button(type="submit" class="btn-unfollow") Dejar de seguir
          else
            form(action=`/profile/${profileUser.username}/follow`, method="POST")
              button(type="submit" class="btn-follow") Seguir
      
      //- Contadores
      div.profile-stats
        span.stat-item #[strong #{stats.posts}] publicaciones
        span.stat-item #[strong #{stats.followers}] seguidores
        span.stat-item #[strong #{stats.following}] seguidos
            
  //- Grilla de Publicaciones propia del Usuario
  if posts && posts.length > 0
    div.posts-grid
      each post in posts
        div.post-card
          if post.PostImages && post.PostImages.length > 0
            div.post-image-wrapper
              //- El enlace que envuelve la imagen
              a(href=`/posts/${post.id}`)
                img(src=post.PostImages[0].imageUrl, alt=post.title)
          else
            div.post-image-placeholder Sin imagen
            
          div.post-info
            h3
              //- El enlace en el título
              a(href=`/posts/${post.id}` style="color: #fff; text-decoration: none;")= post.title
              
            if post.description
              p.post-desc= post.description

            if post.Tags && post.Tags.length > 0
              div.post-tags
                each etiqueta in post.Tags
                  span.tag-badge #{etiqueta.name}  
                
            div.post-meta-footer
              if post.Ratings && post.Ratings.length > 0
                - var suma = post.Ratings.reduce((a, b) => a + b.stars, 0)
                - var prom = (suma / post.Ratings.length).toFixed(1)
                span.post-rating(style="color: #ffffff;") ★ #{prom}
              else
                span.post-rating(style="color: #888;") ☆ Sin votos
                
              span.post-license #{post.license}
  else
    div.no-posts
      p Este usuario todavía no tiene publicaciones compartidas.