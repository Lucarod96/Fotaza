extends ../layout.pug

block title
  | Fotaza - #{post.title}

block styles
  link(rel="stylesheet", href="/posts.css?v=2")

block content
  div.detail-container
    div.post-main-content
      //- Visualización de la Imagen Principal
      if post.PostImages && post.PostImages.length > 0
        div.carousel-container
          if post.PostImages.length > 1
            button.carousel-btn.carousel-btn-left(onclick="scrollCarousel(-1)") &#10094;
          
          div.detail-image-box(id="imageCarousel")
            each image in post.PostImages
              img(src=image.imageUrl, alt=post.title)
              
          if post.PostImages.length > 1
            button.carousel-btn.carousel-btn-right(onclick="scrollCarousel(1)") &#10095;

          //- Script para mover el carrusel
          script.
            function scrollCarousel(direction) {
              const carousel = document.getElementById('imageCarousel');
              const scrollAmount = carousel.clientWidth;
              carousel.scrollBy({ left: scrollAmount * direction, behavior: 'smooth' });
            }
      
      //- Datos de la publicación
      div.detail-info-box
        //- PROMEDIO DE ESTRELLAS REAL
        div.rating-display(style="margin-bottom: 0.5rem; display: flex; align-items: center; gap: 8px;")
          span(style="color: #f1c40f; font-size: 1.1rem;") ★ #{promedioEstrellas}
          span(style="color: #666; font-size: 0.85rem;") (#{totalVotos} valoraciones)

        h1= post.title
        if post.User
          p.detail-author Por: 
            a(href=`/profile/${post.User.username}`, class="author-link") @#{post.User.username}
        if post.description
          p.detail-desc= post.description
        span.post-license Licencia: #{post.license}

        //- FORMULARIO DINÁMICO DE ESTRELLAS (Solo usuarios registrados que no sean el autor)
        if currentUser 
          if currentUser.id !== post.userId
            div.rate-action-box(style="margin-top: 1.5rem; padding-top: 1.2rem; border-top: 1px solid rgba(255,255,255,0.05);")
              p(style="color: #888; margin-bottom: 0.4rem; font-size: 0.85rem;") Calificá esta publicación:
              form(action=`/posts/${post.id}/rate`, method="POST" class="star-rating-form")
                div.stars
                  input(type="radio" id="star5" name="stars" value="5" onchange="this.form.submit()")
                  label(for="star5" title="5 estrellas")
                  
                  input(type="radio" id="star4" name="stars" value="4" onchange="this.form.submit()")
                  label(for="star4" title="4 estrellas")
                  
                  input(type="radio" id="star3" name="stars" value="3" onchange="this.form.submit()")
                  label(for="star3" title="3 estrellas")
                  
                  input(type="radio" id="star2" name="stars" value="2" onchange="this.form.submit()")
                  label(for="star2" title="2 estrellas")
                  
                  input(type="radio" id="star1" name="stars" value="1" onchange="this.form.submit()")
                  label(for="star1" title="1 estrella")
          else
            div.rate-action-box(style="margin-top: 1.5rem; padding-top: 1.2rem; border-top: 1px solid rgba(255,255,255,0.05);")
              p(style="color: #666; font-size: 0.85rem; font-style: italic;") Es tu publicación (no puedes autovalorarte).

    //- SECCIÓN DE COMENTARIOS
    div.comments-section
      h3 Comentarios (#{comments.length})
      
      //- Lista de comentarios
      div.comments-list
        if comments && comments.length > 0
          each comment in comments
            div.comment-card
              p.comment-meta
                strong @#{comment.User.username} 
              p.comment-content= comment.content
        else
          p.no-comments Todavía no hay comentarios. ¡Sé el primero en opinar!

      //- Formulario para comentar
      if currentUser
        form(action=`/posts/${post.id}/comments`, method="POST" class="comment-form")
          div.form-group
            textarea(name="content" placeholder="Escribe un comentario respetuoso..." rows="3" required)
          button(type="submit" class="btn-submit" style="margin-top: 0.5rem;") Comentar
      else
        p.login-to-comment 
          a(href="/auth/login") Inicia sesión
          |  para dejar un comentario.