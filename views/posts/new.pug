extends ../layout

block styles
  link(rel="stylesheet", href="/posts.css")

block content
  div.container
    div.form-wrapper
      
      div.form-header
        h1 Comparte tu arte
        p Sube tus mejores capturas a la comunidad

      if alert && alert.status === 'error'
        div.alerta-error
          span #{alert.text}

      form(method='POST', action='/posts/new', enctype='multipart/form-data', novalidate)
        
        div.form-group
          label(for='title') Título de la obra
          input(type='text', id='title', name='title', required, placeholder="Ej: Atardecer en la montaña")
        
        div.form-group
          label Fotografías
          label.upload-zone(for='images')
            span.upload-icon(id="uploadIcon") 📸
            span.upload-text(id="uploadText") Seleccionar imágenes
            span.upload-subtext(id="uploadSubtext") Puedes elegir varios archivos a la vez
            input(type='file', id='images', name='images', accept="image/png, image/jpeg, image/webp", multiple, required)

        div.form-group
          label(for='tags') Etiquetas
          input(type='text', id='tags', name='tags', placeholder="Ej: paisaje, montaña, f1", required)
          small Sepáralas usando comas

        div.form-group
          label(for='description') Historia detrás de la foto (Opcional)
          textarea(id='description', name='description', rows="3", placeholder="Cuéntanos un poco más sobre este momento...")
        
        div.form-group
          label(for='license') Tipo de Licencia
          div.select-wrapper
            select(id='license', name='license')
              option(value='Sin copyright') Dominio Público (Sin copyright)
              option(value='Con Copyright') Todos los derechos reservados (Con Copyright)
        
        button(type='submit', class='btn-submit') Publicar en el Feed

    script.
        const fileInput = document.getElementById('images');
        const uploadText = document.getElementById('uploadText');
        const uploadSubtext = document.getElementById('uploadSubtext');
        const uploadIcon = document.getElementById('uploadIcon');
        const uploadZone = document.querySelector('.upload-zone');

        fileInput.addEventListener('change', function() {
          const cantidadArchivos = this.files.length;
          
          if (cantidadArchivos > 0) {
            uploadIcon.textContent = '✔️';
            uploadText.textContent = `¡${cantidadArchivos} ${cantidadArchivos === 1 ? 'imagen seleccionada' : 'imágenes seleccionadas'}!`;
            uploadSubtext.textContent = 'Haz clic si deseas cambiar la selección';
            
            uploadZone.style.borderColor = '#10b981';
            uploadZone.style.background = 'rgba(16, 185, 129, 0.02)';
          } else {
            uploadIcon.textContent = '📸';
            uploadText.textContent = 'Seleccionar imágenes';
            uploadSubtext.textContent = 'Puedes elegir varios archivos a la vez';
            uploadZone.style.borderColor = '#333';
            uploadZone.style.background = '#181818';
          }
        });